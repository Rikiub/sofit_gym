{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "allowJs": true,
        "checkJs": false,
        "paths": {
            "@/*": [
                "./assets/*"
            ]
        }
    },
    "include": [
        "./assets/**/*.js",
        "./app/views/**/*.php"
    ]
}